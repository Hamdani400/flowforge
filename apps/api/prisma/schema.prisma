generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  workflows Workflow[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  definition  Json
  version     Int      @default(1)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id])

  runs        WorkflowRun[]
}

model WorkflowRun {
  id          String            @id @default(cuid())
  status      WorkflowRunStatus @default(PENDING)

  startedAt   DateTime?
  finishedAt  DateTime?

  logs        Json?

  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id])

  createdAt   DateTime @default(now())
}